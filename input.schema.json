{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "黄道吉日 · 建档输入契约",
  "description": "build_profile() 入参硬约束，杜绝 LLM 自由文本乱造。calculation_basis 已钉死：八字立春分年界 / 12 节气分月界 / 23:00 换日；Vedic ayanamsa = Lahiri 固定不可改。",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "gender", "solar_birth"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 32,
      "description": "档案名（文件名安全，勿含 / \\ : 等）"
    },
    "gender": {
      "type": "string",
      "enum": ["男", "女"],
      "description": "锁死两枚举，杜绝自由文本"
    },
    "solar_birth": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}(:[0-9]{2})?$",
      "description": "公历 ISO8601，如 1995-03-12T08:30:00。农历入参须先转公历再传此字段。"
    },
    "lat": {
      "type": "number",
      "minimum": -90,
      "maximum": 90,
      "default": 31.23,
      "description": "出生地纬度"
    },
    "lon": {
      "type": "number",
      "minimum": -180,
      "maximum": 180,
      "default": 121.47,
      "description": "出生地经度"
    },
    "tz": {
      "type": "integer",
      "minimum": -12,
      "maximum": 14,
      "default": 8,
      "description": "时区偏移（小时）"
    },
    "birth_place_name": {
      "type": "string",
      "maxLength": 64,
      "default": "未知"
    },
    "time_precision": {
      "type": "string",
      "enum": ["exact", "hour", "unknown"],
      "default": "exact",
      "description": "生时精度门：exact=完整四柱 / hour=时柱精度降、命宫上升低信 / unknown=仅年月日柱、degraded"
    },
    "label": {
      "type": "string",
      "maxLength": 16,
      "default": "",
      "description": "关系备注：我/对象/孩子/父母/合伙人/朋友等（自由短文本，可空）"
    },
    "save": {
      "type": "boolean",
      "default": true,
      "description": "false=临时合盘不落盘"
    },
    "use_true_solar": {
      "type": "boolean",
      "default": true,
      "description": "八字是否使用真太阳时校正；默认 true，用户明确要求按钟表时间排盘时设为 false"
    }
  }
}
